# High-accuracy mixed quant profile (shell-safe for zsh/bash).
# Keeps baseline int4 artifacts and adds:
#   encoder-model-mix84.mlpackage
#   decoder_joint-model-mix84.mlpackage
#
# Usage:
#   source configs/parakeet-coreml-v5-hiacc.env
#   bash scripts/run_conversion.sh

# Baseline runtime/export settings.
export PYTHON_BIN=".venv/bin/python"
export SKIP_EXPORT=1
export ENCODER_FRAMES=1200
export DECODER_FRAMES=300
export OPENBENCH_PYTHON="python3.11"
export OPENBENCH_REBUILD_TEXTERRORS=0
export PARAKEET_COREML_MODEL_DIR="$(pwd)/artifacts/parakeet-tdt-0.6b-v2"
export TMPDIR="$(pwd)/artifacts/parakeet-tdt-0.6b-v2/.tmp"
export PARAKEET_STREAM_STEP_SEC=0.25
export PARAKEET_STREAM_AGREEMENT_WINDOW=2

# Compression profile tag used in output model names.
export COMPRESS_SUFFIX="mix84"

# Mixed precision profile:
# - Encoder: int8 (main accuracy lever)
# - Decoder: int4 (small footprint)
export ENCODER_NBITS=8
export DECODER_NBITS=4

# Keep palettization, but enable per-channel pre-scaling on encoder
# to reduce distortion from kmeans clustering.
export ENCODER_ALGORITHM="palettize"
export DECODER_ALGORITHM="palettize"
export ENCODER_MODE="kmeans"
export DECODER_MODE="kmeans"
export ENCODER_GRANULARITY="auto"
export DECODER_GRANULARITY="auto"
export ENCODER_GROUP_SIZE=32
export DECODER_GROUP_SIZE=32
export ENCODER_ENABLE_PER_CHANNEL_SCALE=1
export DECODER_ENABLE_PER_CHANNEL_SCALE=0

# Runtime model selector used by transcriber.
export PARAKEET_COREML_MODEL_SUFFIX="mix84"
