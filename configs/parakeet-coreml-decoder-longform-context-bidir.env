# Optional long-form decode context with both left and right context.
#
# This keeps fixed-size encoder chunks, but only decodes a center span from each
# chunk while using surrounding frames as context.
#
# Example:
#   source configs/parakeet-coreml-fp16-baseline.env
#   source configs/parakeet-coreml-decoder-conservative.env
#   source configs/parakeet-coreml-decoder-longform-context-bidir.env

# 10ms feature hop
export PARAKEET_ENCODER_LEFT_CONTEXT_FRAMES=240
export PARAKEET_ENCODER_RIGHT_CONTEXT_FRAMES=120
