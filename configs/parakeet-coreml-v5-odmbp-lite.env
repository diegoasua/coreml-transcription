# OD-MBP-inspired profile (approximation with CoreMLTools primitives).
#
# Goal: close WER gap by using higher-fidelity encoder compression:
# - Encoder: linear int8 per-channel (better preserves outlier-dominated layers)
# - Decoder: kmeans int4 (small model component)
#
# Keeps baseline int4 artifacts untouched and writes:
#   encoder-model-odmbp-lite.mlpackage
#   decoder_joint-model-odmbp-lite.mlpackage
#
# Usage:
#   source configs/parakeet-coreml-v5-odmbp-lite.env
#   bash scripts/run_conversion.sh

export PYTHON_BIN=".venv/bin/python"
export SKIP_EXPORT=1

# Locked shape settings from v5 baseline.
export ENCODER_FRAMES=1200
export DECODER_FRAMES=300

# OpenBench runner environment.
export OPENBENCH_PYTHON="python3.11"
export OPENBENCH_REBUILD_TEXTERRORS=0

# Runtime artifact paths.
export PARAKEET_COREML_MODEL_DIR="$(pwd)/artifacts/parakeet-tdt-0.6b-v2"
export TMPDIR="$(pwd)/artifacts/parakeet-tdt-0.6b-v2/.tmp"

# Streaming defaults.
export PARAKEET_STREAM_STEP_SEC=0.25
export PARAKEET_STREAM_AGREEMENT_WINDOW=2

# Output suffix for this profile.
export COMPRESS_SUFFIX="odmbp-lite"

# Encoder: linear int8, per-channel.
export ENCODER_ALGORITHM="linear"
export ENCODER_NBITS=8
export ENCODER_MODE="linear_symmetric"
export ENCODER_GRANULARITY="per_channel"
export ENCODER_BLOCK_SIZE=32

# Decoder: kmeans int4.
export DECODER_ALGORITHM="palettize"
export DECODER_NBITS=4
export DECODER_MODE="kmeans"
export DECODER_GRANULARITY="auto"
export DECODER_GROUP_SIZE=32

# Runtime model selector for transcriber.
export PARAKEET_COREML_MODEL_SUFFIX="odmbp-lite"
