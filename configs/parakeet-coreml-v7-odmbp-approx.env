# Fourth quant profile: OD-MBP approximation with current CoreMLTools APIs.
#
# IMPORTANT:
# - This is tensor-level approximation, not true per-layer dual-branch surgery.
# - It keeps a small outlier-heavy subset of weight tensors in fp16 (skip compression),
#   while compressing the rest with mixed 6/8-bit palettization.
#
# Keeps existing artifacts untouched and writes:
#   encoder-model-odmbp-approx.mlpackage
#   decoder_joint-model-odmbp-approx.mlpackage
#
# Usage:
#   source configs/parakeet-coreml-v7-odmbp-approx.env
#   bash scripts/run_conversion.sh

export PYTHON_BIN=".venv/bin/python"
export SKIP_EXPORT=1

# Locked shape settings from v5 baseline.
export ENCODER_FRAMES=1200
export DECODER_FRAMES=300

# OpenBench runner environment.
export OPENBENCH_PYTHON="python3.11"
export OPENBENCH_REBUILD_TEXTERRORS=0

# Runtime artifact paths.
export PARAKEET_COREML_MODEL_DIR="$(pwd)/artifacts/parakeet-tdt-0.6b-v2"
export TMPDIR="$(pwd)/artifacts/parakeet-tdt-0.6b-v2/.tmp"

# Streaming defaults.
export PARAKEET_STREAM_STEP_SEC=0.25
export PARAKEET_STREAM_AGREEMENT_WINDOW=2

# Output suffix for this profile.
export COMPRESS_SUFFIX="odmbp-approx"

# Encoder: mixed palettization with fp16 escape set.
export ENCODER_ALGORITHM="palettize_mixed"
export ENCODER_MODE="kmeans"
export ENCODER_NBITS=6
export ENCODER_MIXED_HIGH_NBITS=8
export ENCODER_MIXED_HIGH_ELEMENT_RATIO=0.45
export ENCODER_MIXED_FP16_ELEMENT_RATIO=0.08
export ENCODER_MIXED_SCORE_MODE="outlier_ratio"
export ENCODER_MIXED_SAMPLE_SIZE=200000
export ENCODER_GRANULARITY="per_tensor"
export ENCODER_GROUP_SIZE=32
export ENCODER_ENABLE_PER_CHANNEL_SCALE=0

# Decoder remains tiny and aggressively compressed.
export DECODER_ALGORITHM="palettize"
export DECODER_MODE="kmeans"
export DECODER_NBITS=4
export DECODER_GRANULARITY="auto"
export DECODER_GROUP_SIZE=32

# Runtime model selector.
export PARAKEET_COREML_MODEL_SUFFIX="odmbp-approx"
