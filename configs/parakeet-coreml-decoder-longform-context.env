# Optional long-form decode context for fixed-shape encoder chunks.
#
# Adds left-context frames to each encoder chunk and only decodes the
# non-overlapping center span. This reduces boundary errors on long audio.
#
# Example:
#   source configs/parakeet-coreml-fp16-baseline.env
#   source configs/parakeet-coreml-decoder-conservative.env
#   source configs/parakeet-coreml-decoder-longform-context.env

# 10ms feature hop => 240 frames ~= 2.4s of left context.
export PARAKEET_ENCODER_LEFT_CONTEXT_FRAMES=240
