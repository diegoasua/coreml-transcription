# Conservative TDT decoder settings for long-form speech.
#
# Goal:
# - Reduce insertion-heavy failure modes on long recordings.
# - Keep runtime real-time while improving stability.
#
# Source this after your base model profile.
#
# Example:
#   source configs/parakeet-coreml-fp16-baseline.env
#   source configs/parakeet-coreml-decoder-conservative.env

# Limit symbol expansion per encoder frame.
export PARAKEET_TDT_MAX_SYMBOLS_PER_STEP=4

# Cap tokens emitted per encoder chunk to prevent runaway repetition.
export PARAKEET_TDT_MAX_TOKENS_PER_CHUNK=192
