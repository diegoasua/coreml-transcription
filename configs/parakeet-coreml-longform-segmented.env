# Longform transcription overlay for OpenBench earnings-style datasets.
# Source after your base model profile.
#
# Example:
#   source configs/parakeet-coreml-v7-odmbp-approx.env
#   source configs/parakeet-coreml-longform-segmented.env
#
# This uses independent decoder runs per segment with overlap stitching.
# It often improves long recordings versus a single continuous pass.

export PARAKEET_LONGFORM_SEGMENT_SEC=30
export PARAKEET_LONGFORM_OVERLAP_SEC=3

