# FP16 baseline profile for accuracy ceiling checks (no weight compression).
#
# Uses uncompressed CoreML artifacts produced in step [3]:
#   encoder-model.mlpackage
#   decoder_joint-model.mlpackage
#
# Usage:
#   source configs/parakeet-coreml-fp16-baseline.env
#   # optional: regenerate uncompressed models
#   SKIP_EXPORT=1 bash scripts/run_conversion.sh

export PYTHON_BIN=".venv/bin/python"
export SKIP_EXPORT=1

# Keep shape settings aligned with the tuned profiles for fair comparison.
export ENCODER_FRAMES=1200
export DECODER_FRAMES=300

# OpenBench runner environment.
export OPENBENCH_PYTHON="python3.11"
export OPENBENCH_REBUILD_TEXTERRORS=0

# Runtime artifact paths.
export PARAKEET_COREML_MODEL_DIR="$(pwd)/artifacts/parakeet-tdt-0.6b-v2"
export TMPDIR="$(pwd)/artifacts/parakeet-tdt-0.6b-v2/.tmp"

# Force uncompressed model names (ignore suffix routing).
export PARAKEET_COREML_ENCODER_MODEL="encoder-model.mlpackage"
export PARAKEET_COREML_DECODER_MODEL="decoder_joint-model.mlpackage"

# Streaming defaults.
export PARAKEET_STREAM_STEP_SEC=0.25
export PARAKEET_STREAM_AGREEMENT_WINDOW=2
